{
  "name": "De-Time",
  "distribution_name": "de-time",
  "preferred_runtime_package": "detime",
  "legacy_runtime_package": "tsdecomp",
  "type": "time-series decomposition package",
  "stable_entrypoints": [
    "decompose(series, config)",
    "DecompositionConfig",
    "detime run",
    "detime batch",
    "detime profile",
    "detime schema",
    "detime recommend"
  ],
  "machine_entrypoints": [
    "MethodRegistry.list_catalog()",
    "python -m detime.mcp.server",
    "src/detime/schema_assets/*.json"
  ],
  "best_first_methods": {
    "known_period_univariate": [
      "STD",
      "STDR"
    ],
    "general_univariate": [
      "SSA"
    ],
    "multivariate": [
      "MSSA"
    ],
    "adaptive_modes": [
      "EMD",
      "CEEMDAN",
      "VMD",
      "MVMD",
      "MEMD"
    ]
  },
  "artifact_contract": [
    "*_components.csv",
    "*_meta.json",
    "*_components_3d.npz",
    "*_summary.json",
    "*_full.json"
  ],
  "legacy_entrypoints": [
    "tsdecomp run",
    "tsdecomp batch",
    "tsdecomp profile"
  ],
  "companion_benchmark_repo": "https://github.com/systems-mechanobiology/de-time-bench"
}
