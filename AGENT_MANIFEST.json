{
  "name": "De-Time",
  "distribution_name": "de-time",
  "preferred_runtime_package": "detime",
  "legacy_runtime_package": "tsdecomp",
  "legacy_alias_window": "0.1.x",
  "legacy_alias_earliest_removal": "0.2.0",
  "machine_contract_version": "0.1",
  "type": "time-series decomposition package",
  "stable_entrypoints": [
    "decompose(series, config)",
    "DecompositionConfig",
    "detime run",
    "detime batch",
    "detime profile",
    "detime schema",
    "detime recommend"
  ],
  "machine_entrypoints": [
    "MethodRegistry.list_catalog()",
    "python -m detime.mcp.server",
    "src/detime/schema_assets/*.json"
  ],
  "mcp": {
    "status": "local-first",
    "tool_names": [
      "list_methods",
      "get_schema",
      "recommend_method",
      "run_decomposition",
      "summarize_result"
    ],
    "recommended_tool_subsets": {
      "routing": [
        "list_methods",
        "get_schema",
        "recommend_method"
      ],
      "bounded_context_execution": [
        "list_methods",
        "get_schema",
        "recommend_method",
        "run_decomposition",
        "summarize_result"
      ]
    }
  },
  "best_first_methods": {
    "known_period_univariate": [
      "STD",
      "STDR"
    ],
    "general_univariate": [
      "SSA"
    ],
    "multivariate": [
      "MSSA"
    ],
    "adaptive_modes": [
      "EMD",
      "CEEMDAN",
      "VMD",
      "MVMD",
      "MEMD"
    ]
  },
  "artifact_contract": [
    "*_components.csv",
    "*_meta.json",
    "*_components_3d.npz",
    "*_summary.json",
    "*_full.json"
  ],
  "legacy_entrypoints": [
    "tsdecomp run",
    "tsdecomp batch",
    "tsdecomp profile"
  ],
  "versioning_policy": "Machine-facing contracts aim to stay stable within the 0.1 series; breaking changes should land with a package minor bump.",
  "companion_benchmark_repo": "https://github.com/systems-mechanobiology/de-time-bench"
}
